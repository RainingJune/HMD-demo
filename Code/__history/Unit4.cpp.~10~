void __fastcall TForm4::Image2MouseMove(TObject *Sender, TShiftState Shift, int X,
          int Y)
{
	int client_ori_x=Form4->GetClientOrigin().x;
	int client_ori_y=Form4->GetClientOrigin().y;

	GetCursorPos(&cur_pt);
	int x_left=Image2->Left+0.25*Image2->Width+client_ori_x;  //蛁砩諦誧⑹釴梓迵そ躉釴梓祥肮,蔚淕跺勤砓煦傖匐輸⑹郖
	int x_right=Image2->Left+0.75*Image2->Width+client_ori_x;
	int y_top=Image2->Top+0.25*Image2->Height+client_ori_y;
	int y_bottom=Image2->Top+0.75*Image2->Height+client_ori_y;
	if(cur_pt.x>=x_left&&cur_pt.x<x_right&&
	   cur_pt.y>=y_top&&cur_pt.y<=y_bottom)
		Form4->Cursor=crSizeAll;
	else if(cur_pt.x>=Image2->Left+client_ori_x&&cur_pt.x<x_left&&
	   cur_pt.y>=Image2->Top+client_ori_y&&cur_pt.y<=y_top)
		Form4->Cursor=crSizeNWSE;
	else if(cur_pt.x>=x_left&&cur_pt.x<x_right&&
	   cur_pt.y>=Image2->Top+client_ori_y&&cur_pt.y<=y_top)
		Form4->Cursor=crSizeNS;
	else if(cur_pt.x>=x_right&&cur_pt.x<=Image2->Left+Image2->Width+client_ori_x&&
	   cur_pt.y>=Image2->Top+client_ori_y&&cur_pt.y<=y_top)
		Form4->Cursor=crSizeNESW;
	else if(cur_pt.x>=x_right&&cur_pt.x<=Image2->Left+Image2->Width+client_ori_x&&
	   cur_pt.y>=y_top&&cur_pt.y<=y_bottom)
		Form4->Cursor=crSizeWE;
	else if(cur_pt.x>=x_right&&cur_pt.x<=Image2->Left+Image2->Width+client_ori_x&&
	   cur_pt.y>=y_bottom&&cur_pt.y<=Image2->Top+Image2->Height+client_ori_y)
		Form4->Cursor=crSizeNWSE;
	else if(cur_pt.x>=x_left&&cur_pt.x<=x_right&&
	   cur_pt.y>=y_bottom&&cur_pt.y<=Image2->Top+Image2->Height+client_ori_y)
		Form4->Cursor=crSizeNS;
	else if(cur_pt.x>=Image2->Left+client_ori_x&&cur_pt.x<=x_left&&
	   cur_pt.y>=y_bottom&&cur_pt.y<=Image2->Top+Image2->Height+client_ori_y)
		Form4->Cursor=crSizeNESW;
    else if(cur_pt.x>=Image2->Left+client_ori_x&&cur_pt.x<=x_left&&
	   cur_pt.y>=y_top&&cur_pt.y<=y_bottom)
		Form4->Cursor=crSizeNESW;

}
