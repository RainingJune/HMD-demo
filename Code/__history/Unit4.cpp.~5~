//---------------------------------------------------------------------------

#include <vcl.h>
#pragma hdrstop

#include "Unit4.h"
//---------------------------------------------------------------------------
#pragma package(smart_init)
#pragma resource "*.dfm"
TForm4 *Form4;
POINT ori_pt;
POINT cur_pt;
bool IsImage2MouseDown=False;
bool IsRectEdge=False;
//---------------------------------------------------------------------------
__fastcall TForm4::TForm4(TComponent* Owner)
	: TForm(Owner)
{
}
//---------------------------------------------------------------------------

void __fastcall TForm4::Image2MouseDown(TObject *Sender, TMouseButton Button, TShiftState Shift,
		  int X, int Y)
{
						 GetCursorPos(&ori_pt);
						 IsImage2MouseDown=True;
						 //맣긴柑깃루목
}
//---------------------------------------------------------------------------
void __fastcall TForm4::Image2MouseUp(TObject *Sender, TMouseButton Button, TShiftState Shift,
          int X, int Y)
{
		if(IsImage2MouseDown==True){
		GetCursorPos(&cur_pt);
		Image2->Top=Image2->Top+ cur_pt.y-ori_pt.y;
		Image2->Left=Image2->Left+cur_pt.x-ori_pt.x;
		}
		//뿟릿柑깃루목
}
//---------------------------------------------------------------------------

void __fastcall TForm4::Image2DblClick(TObject *Sender)
{
			 GetCursorPos(&cur_pt);
			 int x1=Image2->Left;
			 int y1=Image2->Top;
			 int x2=Image2->Left+Image2->Width;
			 int y2=Image2->Top+Image2->Height;   //狼겉top ,Height돨貫零봤봤悧써苟
			 Canvas->Pen->Color=clWhite;
			 Canvas->Pen->Width=5;
			 Canvas->Pen->Style=psDash;
			 Canvas->MoveTo(x1,y1);
			 Canvas->LineTo(x2,y1);
			 Canvas->LineTo(x2,y2);
			 Canvas->LineTo(x1,y2);
			 Canvas->LineTo(x1,y1);
			 IsRectEdge=True;
}
//---------------------------------------------------------------------------



