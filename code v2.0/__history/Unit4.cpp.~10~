void TForm4::DrawLadderPartC(int x,int y,int gap)
{
	int x_1=x;
	for(int i=1;i<=4;i++){
		  Form4->Canvas->MoveTo(x_1,y);
		  x_1=x_1+gap;
		  Form4->Canvas->LineTo(x_1,y);
		  x_1=x_1+gap;
		  }
	int x_2=x;
	for(int i=1;i<=4;i++){
		  Form4->Canvas->MoveTo(x_2-gap*2,y);
		  x_2=x_2-gap;
		  Form4->Canvas->LineTo(x_2,y);
		  x_2=x_2-gap;
		  }
}
