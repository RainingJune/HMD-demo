void __fastcall TForm4::Button1Click(TObject *Sender)
{
	WSADATA wsaData;                                   //жИЯђWinSocketаХЯЂНсЙЙЕФжИеы
	SOCKET sockListener;
	SOCKADDR_IN sin, saClient;                          //ЩшжУСНИіЕижЗЃЌsinгУРДАѓЖЈ
	//saClientгУРДДгЙуВЅЕижЗНгЪеЯћЯЂ
   //	char cRecvBuff[800];                               //ЖЈвхНгЪеЛКГхЧј
	int nSize, nbSize;
	int iAddrLen = sizeof(saClient);
	if (WSAStartup(MAKEWORD(1, 1), &wsaData) != 0)           //НјааWinSocketЕФГѕЪМЛЏ
		ShowMessage("Can't initiates windows socket!Program stop.\n");//ГѕЪМЛЏЪЇАмЗЕЛи-1
	sockListener = socket(AF_INET, SOCK_DGRAM, 0);
	sin.sin_family = AF_INET;
	sin.sin_port = htons(5500);             //ЗЂЫЭЖЫЪЙгУЕФЗЂЫЭЖЫПкЃЌПЩвдИљОнашвЊИќИФ
	sin.sin_addr.s_addr = htonl(INADDR_ANY);
	if (bind(sockListener, (SOCKADDR FAR *)&sin, sizeof(sin)) != 0)
		ShowMessage("Can't bind socket to local port!Program stop.\n");//ГѕЪМЛЏЪЇАмЗЕЛи-1
	while (loop_flag)
	{
		char* cRecvBuff=new char[800];
		nSize = sizeof (SOCKADDR_IN);
		if ((nbSize = recvfrom(sockListener, cRecvBuff, 800, 0,
			(SOCKADDR FAR *) &saClient, &nSize)) == SOCKET_ERROR) //ШєНгЪеЪЇАмдђЬсЪОДэЮѓ
		{
			ShowMessage("Recive Error");
			break;
		}
		cRecvBuff[nbSize] = '\0';                              //зжЗћДЎжежЙ
		//ShowMessage("%s\n", cRecvBuff);

		//НтЮізжЗћДЎ

		//НтЮіmach number
		char* mach_number=new char[5];
		int i=0;
		for(i=0;i<=4;i++)
			mach_number[i]=cRecvBuff[i];
		StaticText1->Caption=Trim(mach_number);   //Trim ШЅЕєЮВВПЕФПеИё

		//НтЮіGround speed
		char* ground_speed=new char[6];
			for(i=6;i<=11;i++)
				ground_speed[i-6]=cRecvBuff[i];
		StaticText2->Caption=Trim(ground_speed)+"kts";

		//НтЮіG load
		char* g_load=new char[5];
			for(i=13;i<=17;i++)
				g_load[i-13]=cRecvBuff[i];
		StaticText3->Caption=Trim(g_load);

		//НтЮіAGL
		char* agl=new char[7];
			for(i=19;i<=25;i++)
				agl[i-19]=cRecvBuff[i];
		StaticText4->Caption=Trim(agl);

		//НтЮіKIAS-vertical
		char* kias_vertical=new char[3];
			for(i=27;i<=29;i++)
				kias_vertical[i-27]=cRecvBuff[i];
		StaticText5->Caption=Trim(kias_vertical);

		//НтЮіAltitude-ft
		char* altitude_ft=new char[4];
			for(i=31;i<=34;i++)
				altitude_ft[i-31]=cRecvBuff[i];
		StaticText6->Caption=Trim(altitude_ft);

		//НтЮіGyro Heading Label
		char* gyro_label=new char[4];
			for(i=36;i<=39;i++)
				gyro_label[i-36]=cRecvBuff[i];
		StaticText7->Caption=Trim(gyro_label);

		//жиЛцgyrocompass


	  delete cRecvBuff;
	  delete mach_number;
	  delete ground_speed;
	  delete g_load;
	  delete agl;
	  delete kias_vertical;
	  delete altitude_ft;
	  delete gyro_label;
	}
}
