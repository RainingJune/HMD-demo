__fastcall TForm4::TForm4(TComponent* Owner)
	: TForm(Owner)
{
}
//---------------------------------------------------------------------------
void TForm4::DrawAimingReticle(int x,int y,int r1,int r2)
{
		Form4->Canvas->Pen->Color=clLime;
		Form4->Canvas->Pen->Width=10;
		Form4->Canvas->Arc(100,100,200,200,200,160,200,150);
}
void __fastcall TForm4::FormCreate(TObject *Sender)
{
			 DrawAimingReticle(1,1,1,1);
}
